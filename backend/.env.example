# Dentzy backend email configuration (Gmail SMTP)
# Copy this file to backend/.env and replace with your real app password.
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_google_app_password_without_spaces
SMTP_TIMEOUT_SECONDS=15

# Database configuration (MySQL production, SQLite fallback for local dev)
DATABASE_URL=mysql+pymysql://root:PASSWORD@localhost/dentzy_db

# JWT configuration
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional existing backend keys
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TIMEOUT_SECONDS=15

